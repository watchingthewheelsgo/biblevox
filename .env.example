# WaveSpeed API key (server-side only — used by `npm run dev:server`)
# Get a key at https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=

# Google Cloud Text-to-Speech (Chirp 3 HD — Gemini preset voices on Reader)
# Path to service account JSON with roles/texttospeech.user or use gcloud ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: API port (default 8787)
# PORT=8787

# PostgreSQL for better-auth + entitlements
DATABASE_URL=postgres://postgres:postgres@localhost:5432/biblevox

# Better Auth
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_BASE_URL=http://localhost:8787
FRONTEND_URL=http://localhost:5173

# Optional: email verification (same variable style as voicex)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Creem (same naming style as voicex)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_CHAPTER_PRODUCT_ID=
CREEM_UNLOCK_PRODUCT_ID=
